# ========================================
# Backend .gitignore
# ========================================
# Ignore dependency directories
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Ignore environment variables
.env
.env.local
.env.*.local

# Ignore bundler cache
.cache/
dist/
build/

# Ignore OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Ignore IDE
.vscode/
.idea/
*.code-workspace

# Ignore logs
logs/
*.log

# Ignore database files (nếu sử dụng SQLite)
*.sqlite
*.db
