# ========================================
# Database Environment Variables
# ========================================
# File này là MẪU - KHÔNG commit vào git
# Hãy rename thành .env và điền thông tin thực tế của bạn

# MySQL Database Host
# Ví dụ: localhost, 127.0.0.1, hoặc IP server
DB_HOST=localhost

# MySQL Database Port (mặc định 3306)
DB_PORT=3306

# MySQL Database Name
DB_NAME=sport_booking

# MySQL Username
DB_USER=root

# MySQL Password
DB_PASS=123456

# ========================================
# Logging Configuration
# ========================================
# Set sang 'true' để log tất cả SQL queries (dùng cho debug)
# Set sang 'false' để tắt logging (production)
DB_LOGGING=false

# ========================================
# Environment
# ========================================
NODE_ENV=development
